# secondwind 로컬 환경변수 템플릿
# 이 파일은 커밋됩니다. 실제 값은 .env.local 에 넣으세요 (.gitignore 로 제외됨).

# Gemini 2.5 Flash Lite API key
# 발급: https://aistudio.google.com/apikey
# 무료 티어: 1000 RPD / 15 RPM / 250K TPM (프로젝트당)
GEMINI_API_KEY=

# Naver Local Search API (장소 정보 enrich)
# 발급: https://developers.naver.com/apps/#/register
#   - 사용 API: "검색" 체크
#   - 비로그인 오픈 API 서비스 환경: "WEB 설정" 체크, URL: http://localhost:3000
# 무료 티어: 25,000 req/day. 개인 개발자 즉시 사용 가능 (비즈 전환 불필요)
# 미설정 시 장소 enrichment 는 skip (LLM 출력만 사용)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Kakao Maps JS SDK 키 (클라이언트 번들에 노출되므로 origin 검증으로 보호)
# 발급: https://developers.kakao.com/console/app → 앱 → 플랫폼 키 → JavaScript 키
# JS SDK 는 비즈 앱 전환 불필요. Web 플랫폼 도메인 등록 권장 (없어도 많은 경우 동작).
# 미설정 시 지도 섹션 자동 숨김
NEXT_PUBLIC_KAKAO_JS_KEY=

# 점검 모드: 1 로 설정하면 /api/gemini 가 즉시 503 "점검 중" 반환
# GEMINI_DISABLED=

# 프롬프트 버전 태그 (로그·회귀 추적용, 미설정 시 "dev")
# PROMPT_VERSION=2026-04-22-a
